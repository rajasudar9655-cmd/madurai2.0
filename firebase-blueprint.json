{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the authenticated user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email"]
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "A single chat conversation history",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "role": { "type": "string", "enum": ["user", "assistant"] },
              "content": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "required": ["id", "title", "lastUpdated", "messages"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Root collection for user profiles"
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": "ChatSession",
      "description": "Subcollection for storing chat sessions for a specific user"
    }
  }
}
